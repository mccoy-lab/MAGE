#!/usr/bin/env python3

"""
DESCRIPTION:
    Pipeline will run generate leafcutter output, beginning with a directory of STAR-aligned bam files.

USAGE: 
    snakemake --configfile workflow/config.yaml --profile path/to/profile/ -p 
"""

#--- IMPORTS ---#
import pathlib
import pandas as pd

#--- CONFIGURATION ---#
# configure shell behavior for all rules
shell.executable("/bin/bash")
shell.prefix("set -euo pipefail;")

# Create a log directory
pathlib.Path("logs/").mkdir(parents=True, exist_ok=True)

#--- FUNCTION VARIABLE DECLARATION ---#

#--- STATIC VARIABLE DECLARATION ---#
# chroms = list(range(1,23)) # define autosome list

#--- DYNAMIC VARIABLE DECLARATION ---#
'''
Read the tsv stored in config['focal_metadata'] and config['total_metadata'] into 
pandas dataframes and extract the `internal_libraryID` column as a list that can be used
for iterating over samples in the workflow.
'''
focal_metadata_df = pd.read_csv(config["focal_metadata"], sep="\t")
total_metadata_df = pd.read_csv(config["total_metadata"], sep="\t")
focal_libraries = focal_metadata_df["internal_libraryID"].tolist()
total_libraries = total_metadata_df["internal_libraryID"].tolist()


#--- RULES ---#
localrules:
    all,
    install_leafcutter,
    create_junc_list,
    download_gencode_gtf,
    extract_exons_from_gencode

rule all:
    input:
        "results/leafcutter/mage_v1.1_perind.counts.gz"

rule install_leafcutter:
# Clone leafcutter repo to get the cluster_regtools.py script for intron usage quantification
    output:
        leafcutter = directory("workflow/bin/leafcutter/")
    shell:
        """
        git clone https://github.com/davidaknowles/leafcutter.git workflow/bin/leafcutter
        """

rule intron_usage:
# Run regtools to quantify intron usage for each bam file in a directory
    input:
        bam = config["bam_dir"] + "{sample}.bam",
        bam_index = config["bam_dir"] + "{sample}.bam.bai"
    output:
        junc = temp("results/junc/{sample}.Aligned.sortedByCoord.out.bam.junc")
    conda:
        "envs/leafcutter_env.yaml"
    shell:
        """
        regtools junctions extract \
            -s 0 \
            -a 8 \
            -m 50 \
            -M 500000 \
            -o {output.junc} \
            {input.bam}
        """

rule create_junc_list:
# Create a list of all the .junc files generated by regtools to be used as input for leafcutter's cluster_regtools.py script
    input:
        juncs = expand("results/junc/{sample}.Aligned.sortedByCoord.out.bam.junc",
                       sample=total_libraries)
    output:
        temp("results/junc/junc_list.txt")
    shell:
        """
        ls results/junc/*.junc > {output}
        """

rule leafcutter_cluster_regtools:
# Run leafcutter's cluster_regtools.py script to cluster introns based on the regtools output
    input:
        junc_list = rules.create_junc_list.output,
        leafcutter = rules.install_leafcutter.output.leafcutter,
        juncs = expand("results/junc/{sample}.Aligned.sortedByCoord.out.bam.junc",
                       sample=total_libraries)
    output:
        ratios = "results/leafcutter/mage_v1.1_perind.counts.gz",
        leafcutter_dir = directory("results/leafcutter/")
    conda:
        "envs/leafcutter_env.yaml"
    resources:
        time="48:00:00",
        mem_mb=16000
    shell:
        """
        python {input.leafcutter}/clustering/leafcutter_cluster_regtools.py \
            -j {input.junc_list} \
            -r {output.leafcutter_dir} \
            -m 50 \
            -l 500000 \
            -o mage_v1.1
        """

rule download_gencode_gtf:
# Download gencode annotation to be used for extracting exon coordinates
    output:
        gencode = temp("data/gencode.v38.annotation.gtf")
    params:
        gencode_url = config["gencode_url"]
    shell:
        """
        wget -O "{output.gencode}.gz" {params.gencode_url}
        gzip -d "{output.gencode}.gz"
        """

rule extract_exons_from_gencode:
# Extract exon coordinates from gencode annotation
    input:
        exon_extract_script = "workflow/bin/extract_exons_from_gtf.py",
        gencode = rules.download_gencode_gtf.output.gencode
    output:
        temp("results/gencode/gencode_exons.bed")
    conda: 
        "envs/leafcutter_analysis_scripts.yaml"
    shell:
        """
        python {input.exon_extract_script} \
            {input.gencode} \
            --outputFile {output}
        """

rule map_clusters_to_genes:
# Map leafcutter clusters to genes based on overlap 
# with exon coordinates extracted from gencode annotation
    input:
        mapping_script = "workflow/bin/map_clusters_to_genes.R",
        leafcutter_clusters = rules.leafcutter_cluster_regtools.output,
        exon_bed = rules.extract_exons_from_gencode.output
    output:
        "results/leafcutter_analysis/clusters_to_genes.txt"
    conda:
        "envs/leafcutter_analysis_scripts.yaml"
    shell:
        """
        Rscript {input.mapping_script} \
            {input.leafcutter_clusters} \
            {input.exon_bed} \
            {output}
        """


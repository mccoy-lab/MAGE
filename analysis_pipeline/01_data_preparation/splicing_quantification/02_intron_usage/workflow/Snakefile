#!/usr/bin/env python3

"""
DESCRIPTION:
    Pipeline will run generate leafcutter output, beginning with a directory of STAR-aligned bam files.

USAGE: 
    snakemake --configfile config.yaml --profile profile/ -p 
"""

#--- IMPORTS ---#
import pathlib
import pandas as pd

#--- CONFIGURATION ---#
# configure shell behavior for all rules
shell.executable("/bin/bash")
shell.prefix("set -euo pipefail;")

# Create a log directory
pathlib.Path("logs/").mkdir(parents=True, exist_ok=True)

#--- FUNCTION VARIABLE DECLARATION ---#

#--- STATIC VARIABLE DECLARATION ---#
# chroms = list(range(1,23)) # define autosome list

#--- DYNAMIC VARIABLE DECLARATION ---#
'''
Read the tsv stored in config['metadata'] into a pandas dataframe 
and extract the `internal_libraryID` column as a list that can be used
for iterating over samples in the workflow.
'''
metadata_df = pd.read_csv(config["metadata"], sep="\t")
internal_libraryIDs = metadata_df["internal_libraryID"].tolist()


#--- RULES ---#
localrules:
    all,
    install_leafcutter,
    create_junc_list

rule all:
    input:
        "output/leafcutter/mage_v1.1_perind_numers.counts.gz"

rule install_leafcutter:
# Clone leafcutter repo to get the cluster_regtools.py script for intron usage quantification
    output:
        "bin/leafcutter/leafcutter_cluster_regtools.py"
    conda:
        "envs/leafcutter_env.yaml"
    shell:
        """
        git clone https://github.com/davidaknowles/leafcutter.git bin/leafcutter
        """

rule intron_usage:
# Run regtools to quantify intron usage for each bam file in a directory
    input:
        bam = config["bam_dir"] + "{sample}.bam",
        bam_index = config["bam_dir"] + "{sample}.bam.bai"
    output:
        junc = "output/junc/{sample}.Aligned.sortedByCoord.out.bam.junc"
    wildcard_constraints:
        sample = "|".join(internal_libraryIDs)
    conda:
        "envs/leafcutter_env.yaml"
    shell:
        """
        regtools junctions extract \
            -s 0 \
            -a 8 \
            -m 50 \
            -M 500000 \
            -o {output.junc} \
            {input.bam}
        """

rule create_junc_list:
# Create a list of all the .junc files generated by regtools to be used as input for leafcutter's cluster_regtools.py script
    input:
        juncs = expand("output/junc/{sample}.Aligned.sortedByCoord.out.bam.junc",
                       sample=internal_libraryIDs)
    output:
        temp("output/junc/junc_list.txt")
    shell:
        """
        ls output/junc/*.junc > {output}
        """

rule leafcutter_cluster_regtools:
# Run leafcutter's cluster_regtools.py script to cluster introns based on the regtools output
    input:
        junc_list = rules.create_junc_list.output,
        leafcutter_script = rules.install_leafcutter.output
    output:
        "output/leafcutter/mage_v1.1_perind_numers.counts.gz"
    conda:
        "envs/leafcutter_env.yaml"
    shell:
        """
        python bin/leafcutter/leafcutter_cluster_regtools.py \
            -j {input.junc_list} \
            -m 50 \
            -l 500000 \
            -o output/leafcutter/mage_v1.1
        """